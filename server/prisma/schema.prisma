generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VET
  MANAGER
  OPERATOR
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  animals       Animal[]
  paddocks      Paddock[]
  healthRecords HealthRecord[]
  vaccines      Vaccine[]
  treatments    Treatment[]
  estrusCycles  Estrus[]
  pregnancies   Pregnancy[]
  births        Birth[]
  weightRecords WeightRecord[]
  milkProduction MilkProduction[]
  financials    FinancialRecord[]
  alertRules    AlertRule[]
  notifications Notification[]

  @@map("organizations")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  name           String
  role           Role         @default(OPERATOR)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("users")
}

model Animal {
  id             String       @id @default(uuid())
  tag            String       @unique
  species        String       // e.g., Cattle, Sheep
  breed          String?
  sex            String
  birthDate      DateTime
  origin         String?
  status         String       // e.g., Active, Sold, Deceased
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  healthRecords  HealthRecord[]
  vaccines       Vaccine[]
  treatments     Treatment[]
  estrusCycles   Estrus[]
  pregnancies    Pregnancy[]

  birthsAsMother Birth[] @relation("MotherToBirth")
  birthsAsFather Birth[] @relation("FatherToBirth")

  weightRecords  WeightRecord[]
  milkProduction MilkProduction[]

  @@map("animals")
}

model Paddock {
  id             String       @id @default(uuid())
  name           String
  area           Float?       // In hectares or m2
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("paddocks")
}

model HealthRecord {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  date           DateTime @default(now())
  description    String
  observation    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("health_records")
}

model Vaccine {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  vaccineName    String
  doseNumber     Int      @default(1)
  dateAdministered DateTime
  nextDueDate    DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("vaccines")
}

model Treatment {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  diagnosis      String
  medication     String
  dosage         String?
  startDate      DateTime
  endDate        DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("treatments")
}

model Estrus {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime?
  observation    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("estrus")
}

model Pregnancy {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  detectedDate    DateTime
  expectedDate    DateTime?
  status          String   // e.g., Confirmed, Lost, Born
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pregnancies")
}

model Birth {
  id             String   @id @default(uuid())
  motherId       String
  mother         Animal   @relation("MotherToBirth", fields: [motherId], references: [id], onDelete: Cascade)
  fatherId       String?
  father         Animal?  @relation("FatherToBirth", fields: [fatherId], references: [id])
  birthDate      DateTime
  offspringTag   String?
  status         String
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("births")
}

model WeightRecord {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  weight         Float
  date           DateTime @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("weight_records")
}

model MilkProduction {
  id             String   @id @default(uuid())
  animalId       String
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  quantity       Float
  unit           String
  date           DateTime @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("milk_production")
}

model FinancialRecord {
  id             String   @id @default(uuid())
  type           String   // e.g., COST, REVENUE
  category       String   // e.g., Feed, Medicine, Sale, Service
  amount         Float
  date           DateTime @default(now())
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("financial_records")
}

model AlertRule {
  id             String   @id @default(uuid())
  name           String
  condition      String   // e.g., "vaccine_overdue", "production_drop"
  value          String?   // Threshold value
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("alert_rules")
}

model Notification {
  id             String   @id @default(uuid())
  ruleId         String?
  message        String
  isRead         Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("notifications")
}
