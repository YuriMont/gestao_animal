generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  VET
  MANAGER
  OPERATOR
}

enum AnimalStatus {
  ACTIVE
  INACTIVE
  SOLD
  DECEASED
}

enum AnimalSex {
  FEMALE
  MALE
}

enum PregnancyStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BirthStatus {
  ALIVE
  STILLBORN
  ABORTED
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialCategory {
  FEED
  MEDICATION
  LABOR
  MAINTENANCE
  OTHER
}

model Organization {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  animals        Animal[]
  paddocks       Paddock[]
  healthRecords  HealthRecord[]
  vaccines       Vaccine[]
  treatments     Treatment[]
  estrusCycles   Estrus[]
  pregnancies    Pregnancy[]
  births         Birth[]
  weightRecords  WeightRecord[]
  milkProduction MilkProduction[]
  financials     FinancialRecord[]
  alertRules     AlertRule[]
  notifications  Notification[]

  @@map("organizations")
}

model User {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  email          String       @unique
  password       String
  name           String
  role           Role         @default(OPERATOR)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Animal {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  tag            String       @unique
  species        String
  breed          String?
  sex            String
  birthDate      DateTime
  origin         String?
  status         AnimalStatus @default(ACTIVE)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  healthRecords HealthRecord[]
  vaccines      Vaccine[]
  treatments    Treatment[]
  estrusCycles  Estrus[]
  pregnancies   Pregnancy[]

  birthsAsMother Birth[] @relation("MotherToBirth")
  birthsAsFather Birth[] @relation("FatherToBirth")

  weightRecords  WeightRecord[]
  milkProduction MilkProduction[]

  @@map("animals")
}

model Paddock {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  area           Float?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paddocks")
}

model HealthRecord {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  animalId       String       @db.ObjectId
  animal         Animal       @relation(fields: [animalId], references: [id])
  date           DateTime     @default(now())
  description    String
  observation    String?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("health_records")
}

model Vaccine {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  animalId         String       @db.ObjectId
  animal           Animal       @relation(fields: [animalId], references: [id])
  vaccineName      String
  doseNumber       Int          @default(1)
  dateAdministered DateTime
  nextDueDate      DateTime?
  organizationId   String       @db.ObjectId
  organization     Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vaccines")
}

model Treatment {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  animalId       String       @db.ObjectId
  animal         Animal       @relation(fields: [animalId], references: [id])
  diagnosis      String
  medication     String
  dosage         String?
  startDate      DateTime
  endDate        DateTime?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("treatments")
}

model Estrus {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  animalId       String       @db.ObjectId
  animal         Animal       @relation(fields: [animalId], references: [id])
  startDate      DateTime
  endDate        DateTime?
  observation    String?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("estrus")
}

model Pregnancy {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  animalId       String          @db.ObjectId
  animal         Animal          @relation(fields: [animalId], references: [id])
  detectedDate   DateTime
  expectedDate   DateTime?
  status         PregnancyStatus @default(PENDING)
  organizationId String          @db.ObjectId
  organization   Organization    @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pregnancies")
}

model Birth {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  motherId       String       @db.ObjectId
  mother         Animal       @relation("MotherToBirth", fields: [motherId], references: [id])
  fatherId       String?      @db.ObjectId
  father         Animal?      @relation("FatherToBirth", fields: [fatherId], references: [id])
  birthDate      DateTime
  offspringTag   String?
  status         BirthStatus  @default(ALIVE)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("births")
}

model WeightRecord {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  animalId       String       @db.ObjectId
  animal         Animal       @relation(fields: [animalId], references: [id])
  weight         Float
  date           DateTime     @default(now())
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("weight_records")
}

model MilkProduction {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  animalId       String       @db.ObjectId
  animal         Animal       @relation(fields: [animalId], references: [id])
  quantity       Float
  unit           String
  date           DateTime     @default(now())
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("milk_production")
}

model FinancialRecord {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  type           FinancialType
  category       FinancialCategory
  amount         Float
  date           DateTime          @default(now())
  description    String?
  organizationId String            @db.ObjectId
  organization   Organization      @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("financial_records")
}

model AlertRule {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  condition      String
  value          String?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("alert_rules")
}

model Notification {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  ruleId         String?
  message        String
  isRead         Boolean      @default(false)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}
